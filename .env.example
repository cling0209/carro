APP_NAME="Tienda Rómulo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Producción: APP_DEBUG=false, SESSION_SECURE_COOKIE=true
APP_URL=http://localhost:8081
APP_TIMEZONE=America/Santiago

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL

LOG_CHANNEL=stack
LOG_LEVEL=debug
# Local: correos SMTP en storage/logs/mail.log (solo APP_ENV=local)

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=carro
DB_USERNAME=carro
DB_PASSWORD=secret

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120

# Local: SMTP (mailpit o mail.romulo.cl). Producción Render: MAIL_MAILER=resend (ver RENDER.md)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@carro.local
MAIL_FROM_NAME="${APP_NAME}"
# Si la clave tiene # u otros símbolos, usar comillas: MAIL_PASSWORD="tu-clave"

# Resend (solo producción / Render free). Dominio romulo.cl verificado en resend.com
# MAIL_MAILER=resend
# RESEND_API_KEY=
# MAIL_FROM_ADDRESS=tienda@romulo.cl

# Admin: true = login y recuperación con código OTP; false = login directo y enlace por correo
ADMIN_OTP_ENABLED=true

# Admin extra en db:seed (solo local; dejar vacío en producción)
SEED_EXTRA_ADMIN_EMAIL=
SEED_EXTRA_ADMIN_PASSWORD=
SEED_EXTRA_ADMIN_NAME=Administrador

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1
SESSION_DOMAIN=localhost

# Transbank Webpay Plus (integración)
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D054CE46DCDA7AB6C18ADDF1385F3AAABBB9B4
TRANSBANK_ENV=integration
TRANSBANK_RETURN_URL=http://localhost:8081/checkout/webpay/return

L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=http://localhost:8081
# Producción (APP_ENV=production): Swagger UI requiere sesión admin en /api/documentation

# Imágenes productos (URL externa Romulo u otro CDN)
PRODUCT_IMAGE_BASE_URL=https://www.romulo.cl/allproducts/imagenes/productos
PRODUCT_IMAGE_FALLBACK_URL=https://picsum.photos/seed/placeholder/800/800

# Importación masiva productos (CSV/Excel en segundo plano)
PRODUCT_IMPORT_BACKGROUND=true
PRODUCT_IMPORT_AUTO_CREATE_CATEGORIES=true
DB_QUEUE_RETRY_AFTER=3700

# Neon (producción): usa DATABASE_URL en lugar de DB_* si prefieres
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/carro?sslmode=require
